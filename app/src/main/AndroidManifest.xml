<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <queries>
        <package android:name="com.google.android.glasses.core" />
        <package android:name="com.google.android.glasses.companion" />

        <intent>
            <action android:name="androidx.xr.projected.ACTION_BIND" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.ProjectMinos">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.ProjectMinos">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".xr.GlassesMainActivity"
            android:exported="true"
            android:requiredDisplayCategory="xr_projected"
            android:theme="@style/Theme.ProjectMinos" />
    </application>

</manifest>
